{
  "name": "claude-office-dashboard",
  "displayName": "Claude Office Dashboard",
  "description": "Real-time agent activity dashboard for Claude Code",
  "version": "0.2.0",
  "publisher": "shiza039",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": [],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeOffice.showDashboard",
        "title": "Claude Office: Show Dashboard"
      },
      {
        "command": "claudeOffice.clearEvents",
        "title": "Claude Office: Clear Events"
      }
    ],
    "configuration": {
      "title": "Claude Office Dashboard",
      "properties": {
        "claudeOffice.eventsFile": {
          "type": "string",
          "default": "",
          "description": "Path to agent-events.jsonl file"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "tsc -p ./ && node out/test/eventParser.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}
