{
  "name": "claude-office-dashboard",
  "displayName": "Claude Office Dashboard",
  "description": "Real-time agent activity dashboard for Claude Code",
  "version": "0.7.0",
  "publisher": "shiza039",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeOffice",
          "title": "Claude Office",
          "icon": "media/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "claudeOffice": [
        {
          "type": "webview",
          "id": "claudeOffice.dashboard",
          "name": "Dashboard",
          "contextualTitle": "Claude Office"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeOffice.showDashboard",
        "title": "Claude Office: Show Dashboard"
      },
      {
        "command": "claudeOffice.openInEditor",
        "title": "Claude Office: Open Dashboard in Editor",
        "icon": "$(link-external)"
      },
      {
        "command": "claudeOffice.clearEvents",
        "title": "Claude Office: Clear Events"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeOffice.openInEditor",
          "when": "view == claudeOffice.dashboard",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Claude Office Dashboard",
      "properties": {
        "claudeOffice.eventsFile": {
          "type": "string",
          "default": "",
          "description": "Path to agent-events.jsonl file"
        },
        "claudeOffice.usage.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show plan usage panel"
        },
        "claudeOffice.usage.pollSeconds": {
          "type": "number",
          "default": 90,
          "minimum": 30,
          "description": "Usage refresh seconds"
        },
        "claudeOffice.usage.limitBlockUsd": {
          "type": "number",
          "default": 0,
          "description": "Block limit USD"
        },
        "claudeOffice.usage.limitWeeklyUsd": {
          "type": "number",
          "default": 0,
          "description": "Weekly limit USD"
        },
        "claudeOffice.usage.limitWeeklyOpusUsd": {
          "type": "number",
          "default": 0,
          "description": "Opus weekly limit USD"
        },
        "claudeOffice.scope": {
          "type": "string",
          "enum": ["workspace", "global"],
          "default": "workspace",
          "description": "workspace = this window only; global = all Claude Code sessions"
        },
        "claudeOffice.agentRooms": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "markdownDescription": "Custom agent→room mapping. Merged **over** the built-in defaults. Example: `{\"my-custom-agent\": \"backend\", \"design-agent\": \"frontend\"}`.\n\nKnown rooms: `directors`, `backend`, `frontend`, `qa`, `security`, `devops`, `integrations`, `ai-lab`, `lobby`.\n\nUnknown agents are resolved by a keyword heuristic (e.g. `*-director` → directors, `react-*` → frontend); unmatched agents fall back to `lobby`."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "tsc -p ./ && node out/test/eventParser.test.js && node out/test/types.test.js && node out/test/agentState.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}
